generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id
  username             String
  email                String   @unique
  image                String
  role                 String   @default("user")
  recentSearchedCities String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  agencies             Agency[]
  bookings      Booking[]
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  address   String
  contact   String
  email     String
  owner     String
  city      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [owner], references: [id])
  cars      Car[] 
  bookings      Booking[]
}

model Car {
  id           String   @id @default(cuid())
  agency       String
  title        String
  description  String
  city         String
  country      String
  address      String
  odometer     Int
  bodyType     String
  price        Float
  transmission String
  seats        Int
  fuelType     String
  features     String[]
  images       String[]
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agencyRef    Agency   @relation(fields: [agency], references: [id])
  bookings      Booking[]
}
model Booking {
  id            String   @id @default(cuid())
  user          String
  car           String
  agency        String
  pickUpDate    DateTime
  dropOffDate   DateTime
  totalPrice    Float
  status        String   @default("pending")
  paymentMethod String   @default("Pay at pickup")
  isPaid        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userRef       User     @relation(fields: [user], references: [id])
  carRef        Car      @relation(fields: [car], references: [id])
  agencyRef     Agency   @relation(fields: [agency], references: [id])
}